{
  "name": "luciteria-collector-cabinet",
  "version": "2.5.0",
  "private": true,
  "description": "Shopify embedded app for the Luciteria Collector Cabinet experience",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "dev:debug": "DEBUG=* remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
    "start:production": "NODE_ENV=production APP_MODE=production remix-serve ./build/server/index.js",
    "lint": "eslint --ignore-path .gitignore .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force && node prisma/seed.js",
    "db:studio": "prisma studio",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev --name init && node prisma/seed.js",
    "setup:production": "npm ci && npx prisma generate && npx prisma migrate deploy && node prisma/seed.js",
    "validate-env": "node -e \"import('./app/config/environment.server.js').then(m => { const r = m.validateEnvironment(); console.log(JSON.stringify(r, null, 2)); process.exit(r.valid ? 0 : 1) })\"",
    "prestart": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@remix-run/node": "^2.8.0",
    "@remix-run/react": "^2.8.0",
    "@remix-run/serve": "^2.8.0",
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^12.20.0",
    "@shopify/polaris-icons": "^9.0.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "isbot": "^5.1.0",
    "nodemailer": "^9.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.8.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.4.17",
    "vite": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
