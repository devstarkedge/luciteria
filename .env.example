# ──────────────────────────────────────────────────────────────
# Luciteria Collector Cabinet — Environment Variables
# Copy to .env and fill in real values for production
# ──────────────────────────────────────────────────────────────

# ── Application Mode ──────────────────────────────────────────
# "prototype" = uses mock in-memory data (no database/Shopify needed)
# "production" = uses real Shopify API + PostgreSQL database
APP_MODE=prototype
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Prototype: SQLite (file-based, no server needed)
DATABASE_URL="file:./dev.db"
# Production: PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/luciteria_cabinet?schema=public"

# ── Session ───────────────────────────────────────────────────
SESSION_SECRET="change-me-in-production-use-a-64-char-random-string"

# ── Shopify API ───────────────────────────────────────────────
# Required in production mode. Get these from your Shopify Partner Dashboard.
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SHOP_DOMAIN=""              # e.g. "luciteria.myshopify.com"
SHOPIFY_ACCESS_TOKEN=""             # Admin API access token
SHOPIFY_STOREFRONT_TOKEN=""         # Storefront API token (optional)
SHOPIFY_WEBHOOK_SECRET=""           # Webhook HMAC validation secret
SHOPIFY_API_VERSION="2024-10"       # Shopify API version to pin

# ── Shopify App (Remix Integration) ──────────────────────────
SCOPES="read_products,write_products,read_customers,write_customers,read_orders,write_orders,read_inventory,write_inventory"

# ── Email / Notification Service ──────────────────────────────
# Integration with transactional email provider
EMAIL_SERVICE_PROVIDER="none"       # "sendgrid" | "postmark" | "ses" | "none"
EMAIL_SERVICE_API_KEY=""
EMAIL_FROM_ADDRESS="noreply@luciteria.com"
EMAIL_FROM_NAME="Luciteria"

# ── Feature Flags ─────────────────────────────────────────────
# Toggle features on/off without code changes
FEATURE_ASSIGNMENT_ENGINE=true      # Enable auto-assignment engine
FEATURE_DISCOUNT_ALERTS=true        # Enable discount threshold alerts
FEATURE_PRECIOUS_METAL_EXCLUSION=true # Exclude precious metals from subscription
FEATURE_GRANDFATHERING=true         # Enable grandfather pricing
FEATURE_EMAIL_NOTIFICATIONS=false   # Enable real email sending (false = console log only)
FEATURE_WEBHOOK_SYNC=false          # Enable Shopify webhook processing
FEATURE_MULTI_COLLECTION=false      # Allow customers to have multiple collection types

# ── Pricing Configuration ────────────────────────────────────
# Default subscription prices per collection type (monthly)
PRICE_LUCITE_MONTHLY=79.99
PRICE_10MM_MONTHLY=49.99
PRICE_25MM_MONTHLY=69.99
PRICE_50MM_MONTHLY=99.99
PRICE_AMPOULES_MONTHLY=59.99

# Discount thresholds
DISCOUNT_ALERT_THRESHOLD=0.20      # 20% - flag for admin review
DISCOUNT_HARD_CAP=0.35             # 35% - never auto-assign above this

# Grandfathering
GRANDFATHER_DEFAULT_MONTHS=12      # How long to lock in old price

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL="info"                   # "debug" | "info" | "warn" | "error"
LOG_FORMAT="text"                  # "text" | "json" (use json in production)

# ── Redis (optional, for caching/job queues) ──────────────────
# REDIS_URL="redis://localhost:6379"

# ── Sentry (optional, for error tracking) ─────────────────────
# SENTRY_DSN=""
